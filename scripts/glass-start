#!/bin/bash
# Enhanced Glass-Box Session Starter
# Starts with glass-summary and integrates OpenClaw session history

echo "╔════════════════════════════════════════════════════════════╗"
echo "║        GLASS-BOX SESSION START                             ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""

# 1. Glass-Box Memory Summary
echo "📊 GLASS-BOX MEMORY:"
~/.openclaw/workspace/scripts/glass-summary 2>/dev/null || echo "  No memory yet"

echo ""

# 2. OpenClaw Session Stats
echo "📋 OPENCLAW SESSIONS:"
~/.openclaw/workspace/scripts/glass-openclaw recent 2>/dev/null | head -5 || echo "  No sessions found"

echo ""

# 3. LM Studio Status
echo "⚡ LM STUDIO:"
if curl -s http://localhost:1234/v1/models 2>/dev/null | jq -r '.data[0].id' &>/dev/null; then
    MODEL=$(curl -s http://localhost:1234/v1/models | jq -r '.data[0].id')
    echo "  ✅ Ready: $MODEL"
else
    echo "  ⚠️  Not responding (start LM Studio for 5x faster iteration)"
fi

echo ""
echo "════════════════════════════════════════════════════════════"
echo "💡 READY TO WORK"
echo "════════════════════════════════════════════════════════════"
echo ""
echo "Memory commands:"
echo "  glass-box hypothesis/test/result \"msg\""
echo "  glass-decision decision/reason/why \"msg\""
echo "  glass-query \"keyword\""
echo ""
echo "AI commands:"
echo "  lm-code \"prompt\" [tokens]    # 2-3s code generation"
echo "  lm-ask \"question\"            # 2s Q&A"
echo ""
